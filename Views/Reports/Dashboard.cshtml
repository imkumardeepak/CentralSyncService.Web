@model Web.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Real-Time Dashboard";
}

<div class="bg-neutral-100 min-h-full">
    <!-- Page Header -->
    <div class="border-b border-neutral-200 bg-white/80 backdrop-blur-sm sticky top-16 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-3">
                        <h1 class="text-2xl font-bold text-neutral-900 tracking-tight">Real-Time Dashboard</h1>
                        @await Html.PartialAsync("_Badge", new { 
                            Variant = Model.IsSyncRunning ? "success" : "danger", 
                            Text = Model.IsSyncRunning ? "Syncing" : "Stopped", 
                            ShowDot = true,
                            Pulse = Model.IsSyncRunning
                        })
                    </div>
                    <p class="mt-1 text-sm text-neutral-500">Live monitoring of sorter scan activity across all plants</p>
                </div>
                
                <div class="flex items-center gap-3 flex-shrink-0">
                    <button type="button" onclick="window.location.reload()" 
                            class="inline-flex items-center px-3 py-2 text-sm font-medium text-neutral-600 bg-white border border-neutral-300 rounded-lg hover:bg-neutral-50 hover:border-neutral-400 transition-all duration-200">
                        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                        Refresh
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-6">
        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 border-l-4 border-red-500 rounded-r-lg p-4">
                <p class="text-sm font-medium text-red-800">@ViewBag.Error</p>
                <p class="text-xs text-red-600 mt-1">Run <strong>CentralDatabase_UpdateScript.sql</strong> on the database to fix this.</p>
            </div>
        }
        <!-- Today Stats Summary -->
        <div class="space-y-6">
            
            <!-- FROM Stats Summary Card -->
            <div class="bg-white rounded-xl shadow-card border-l-4 border-l-blue-500 border-t border-r border-b border-neutral-200 p-6 md:p-8">
                <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-6">
                    <div>
                        <h2 class="text-xl font-bold text-neutral-900 flex items-center gap-2">
                            <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                            </svg>
                            Today Issue Summary (FROM)
                        </h2>
                        <p class="text-sm text-neutral-500 mt-1">
                            Showing data from <strong>7:00 AM</strong> to <strong>6:59 AM of Tomorrow</strong>
                        </p>
                    </div>
                    
                    <div class="flex flex-col sm:flex-row items-center gap-4">
                        <div class="flex items-center justify-between w-full sm:w-auto gap-4 p-3 rounded-lg bg-neutral-50 shadow-sm border border-neutral-100">
                            <span class="text-sm font-bold text-neutral-600 uppercase tracking-wider">Total Issue</span>
                            <span class="inline-flex items-center justify-center min-w-[3rem] rounded-full bg-blue-100 px-3.5 py-1 text-lg font-black text-blue-800">
                                @Model.TodayStats.TotalIssueCount.ToString("N0")
                            </span>
                        </div>
                        <div class="flex items-center justify-between w-full sm:w-auto gap-4 p-3 rounded-lg bg-neutral-50 shadow-sm border border-neutral-100">
                            <span class="text-sm font-bold text-neutral-600 uppercase tracking-wider">Total Read</span>
                            <span class="inline-flex items-center justify-center min-w-[3rem] rounded-full bg-emerald-100 px-3.5 py-1 text-lg font-black text-emerald-800">
                                @Model.TodayStats.TotalIssueRead.ToString("N0")
                            </span>
                        </div>
                        <div class="flex items-center justify-between w-full sm:w-auto gap-4 p-3 rounded-lg bg-neutral-50 shadow-sm border border-neutral-100">
                            <span class="text-sm font-bold text-neutral-600 uppercase tracking-wider">Total No Read</span>
                            <span class="inline-flex items-center justify-center min-w-[3rem] rounded-full bg-red-100 px-3.5 py-1 text-lg font-black text-red-800">
                                @Model.TodayStats.TotalIssueNoRead.ToString("N0")
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TO Stats Summary Card -->
            <div class="bg-white rounded-xl shadow-card border-l-4 border-l-indigo-500 border-t border-r border-b border-neutral-200 p-6 md:p-8">
                <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-6">
                    <div>
                        <h2 class="text-xl font-bold text-neutral-900 flex items-center gap-2">
                            <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
                            </svg>
                            Today Receipt Summary (TO)
                        </h2>
                        <p class="text-sm text-neutral-500 mt-1">
                            Showing data from <strong>7:00 AM</strong> to <strong>6:59 AM of Tomorrow</strong>
                        </p>
                    </div>
                    
                    <div class="flex flex-col sm:flex-row items-center gap-4">
                        <div class="flex items-center justify-between w-full sm:w-auto gap-4 p-3 rounded-lg bg-neutral-50 shadow-sm border border-neutral-100">
                            <span class="text-sm font-bold text-neutral-600 uppercase tracking-wider">Total Receipt</span>
                            <span class="inline-flex items-center justify-center min-w-[3rem] rounded-full bg-indigo-100 px-3.5 py-1 text-lg font-black text-indigo-800">
                                @Model.TodayStats.TotalReceiptCount.ToString("N0")
                            </span>
                        </div>
                        <div class="flex items-center justify-between w-full sm:w-auto gap-4 p-3 rounded-lg bg-neutral-50 shadow-sm border border-neutral-100">
                            <span class="text-sm font-bold text-neutral-600 uppercase tracking-wider">Total Read</span>
                            <span class="inline-flex items-center justify-center min-w-[3rem] rounded-full bg-emerald-100 px-3.5 py-1 text-lg font-black text-emerald-800">
                                @Model.TodayStats.TotalReceiptRead.ToString("N0")
                            </span>
                        </div>
                        <div class="flex items-center justify-between w-full sm:w-auto gap-4 p-3 rounded-lg bg-neutral-50 shadow-sm border border-neutral-100">
                            <span class="text-sm font-bold text-neutral-600 uppercase tracking-wider">Total No Read</span>
                            <span class="inline-flex items-center justify-center min-w-[3rem] rounded-full bg-red-100 px-3.5 py-1 text-lg font-black text-red-800">
                                @Model.TodayStats.TotalReceiptNoRead.ToString("N0")
                            </span>
                        </div>
                    </div>
                </div>
            </div>


    </div>
</div>

@section Scripts {
    <script>
        // Auto-refresh every 30 seconds with loading indication
        setInterval(function() {
            if (window.LoadingManager) {
                window.LoadingManager.showPageLoader();
            }
            window.location.reload();
        }, 30000);
    </script>
}
