@model List<Web.Core.DTOs.OverallTransferByProductionOrderRecord>
@{
    ViewData["Title"] = "OverAll Transfer By Production Order";
    var selectedDate = ViewBag.Date as DateTime? ?? DateTime.Today;
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Page Header -->
    <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">OverAll Transfer By Production Order</h1>
                <p class="mt-1 text-sm text-gray-500">Track production orders with issue/receipt counts and deviation</p>
            </div>
            <div class="flex items-center gap-3">
                <a href="@Url.Action("ExportOverallTransferByOrderExcel", "Reports", new { date = selectedDate })" 
                   class="inline-flex items-center px-3 py-2 text-sm font-medium text-white bg-green-600 border border-green-700 rounded-lg hover:bg-green-700 transition-all duration-200">
                    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    Export Excel
                </a>
                <button type="button" onclick="exportToCSV()" 
                        class="inline-flex items-center px-3 py-2 text-sm font-medium text-neutral-600 bg-white border border-neutral-300 rounded-lg hover:bg-neutral-50 hover:border-neutral-400 transition-all duration-200">
                    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                    </svg>
                    Export CSV
                </button>
                <form method="get" class="flex items-center gap-2">
                    <input type="date" name="date" value="@selectedDate.ToString("yyyy-MM-dd")" 
                           class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
                    <button type="submit" class="px-4 py-2 bg-brand-600 text-white text-sm font-medium rounded-lg hover:bg-brand-700 transition-colors">
                        <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                        Search
                    </button>
                </form>
            </div>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
            <div class="flex items-center">
                <svg class="w-5 h-5 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="text-red-700 font-medium">@ViewBag.Error</span>
            </div>
        </div>
    }

    <!-- Data Table -->
    <div class="bg-white rounded-xl shadow-card overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">Production Order Summary</h2>
            <p class="text-sm text-gray-500">Date: @selectedDate.ToString("MMMM dd, yyyy")</p>
        </div>

        @if (Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Order No</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">SAP Code</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product Name</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Batch</th>
                            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Order Qty</th>
                            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Prod. Qty</th>
                            <th class="px-4 py-3 text-center text-xs font-medium text-blue-600 uppercase tracking-wider">Issue Count</th>
                            <th class="px-4 py-3 text-center text-xs font-medium text-green-600 uppercase tracking-wider">Receipt Count</th>
                            <th class="px-4 py-3 text-center text-xs font-medium text-purple-600 uppercase tracking-wider">Deviation</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-4 py-3 whitespace-nowrap text-sm font-mono text-gray-900">@item.OrderNo</td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm font-mono text-gray-900">@item.MaterialNumber</td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900">@item.MaterialDescription</td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-700">@item.Batch</td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-900 font-semibold">@item.OrderQty.ToString("N0")</td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-900">@item.CurQTY.ToString("N0")</td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm text-center text-blue-600 font-semibold">@item.IssueCount</td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm text-center text-green-600 font-semibold">@item.ReceiptCount</td>
                                <td class="px-4 py-3 whitespace-nowrap text-sm text-center">
                                    @if (item.Deviation > 0)
                                    {
                                        <span class="text-green-600 font-semibold">+@item.Deviation.ToString("N0")</span>
                                    }
                                    else if (item.Deviation < 0)
                                    {
                                        <span class="text-red-600 font-semibold">@item.Deviation.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-600 font-semibold">@item.Deviation.ToString("N0")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-8 text-center">
                <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <h3 class="text-lg font-medium text-gray-900 mb-1">No Data Found</h3>
                <p class="text-gray-500">No production order records found for the selected filters.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function exportToCSV() {
            const table = document.querySelector('table');
            if (!table) return;
            
            if (window.LoadingManager) {
                window.LoadingManager.show('Exporting...', 'Preparing CSV file for download');
            }
            
            let csv = [];
            const rows = table.querySelectorAll('tr');
            
            for (let i = 0; i < rows.length; i++) {
                let row = [], cols = rows[i].querySelectorAll('td, th');
                for (let j = 0; j < cols.length; j++) {
                    let text = cols[j].innerText.trim();
                    text = text.replace(/"/g, '""');
                    if (text.indexOf(',') !== -1 || text.indexOf('"') !== -1 || text.indexOf('\n') !== -1) {
                        text = '"' + text + '"';
                    }
                    row.push(text);
                }
                csv.push(row.join(','));
            }
            
            const BOM = '\uFEFF';
            const csvContent = BOM + csv.join('\n');
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = 'overall_transfer_by_order_@(selectedDate.ToString("yyyy-MM-dd")).csv';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(link.href);
            
            setTimeout(function() {
                if (window.LoadingManager) {
                    window.LoadingManager.hide();
                }
            }, 1000);
        }
    </script>
}
