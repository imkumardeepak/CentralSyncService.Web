@model Web.Models.ViewModels.ScanReadStatusViewModel

@{
    ViewData["Title"] = "Scan Read Status Summary";
}

<div class="container mx-auto px-4 py-6">
    <!-- Header -->
    <div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Scan Read Status Summary</h2>
            <p class="mt-1 text-sm text-gray-500">
                Daily breakdown of Issue (FROM) and Receipt (TO) scan READ / NO READ counts from SorterScans_Sync.
            </p>
        </div>
    </div>

    <!-- Error Message -->
    @if (ViewBag.Error != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 relative overflow-hidden rounded-r-lg shadow-sm">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">Error Loading Report</h3>
                    <div class="mt-2 text-sm text-red-700">
                        <p>@ViewBag.Error</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-card p-5 mb-6 border border-neutral-100 transition-all hover:shadow-card-hover">
        <form method="get" action="@Url.Action("ScanReadStatus", "Reports")" class="flex flex-wrap gap-4 items-end">
            <div>
                <label class="block text-sm font-semibold text-neutral-700 mb-1.5">Start Date</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <input type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")"
                           class="pl-10 border border-neutral-300 rounded-lg px-3 py-2 w-44 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 shadow-sm transition-shadow" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold text-neutral-700 mb-1.5">End Date</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <input type="date" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")"
                           class="pl-10 border border-neutral-300 rounded-lg px-3 py-2 w-44 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 shadow-sm transition-shadow" />
                </div>
            </div>
            <div class="flex gap-3">
                <button type="submit" class="bg-brand-600 text-white px-5 py-2 rounded-lg hover:bg-brand-700 font-medium shadow-sm transition-all focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    Apply Filter
                </button>
            </div>
        </form>
    </div>

    <!-- Data Table -->
    <div class="bg-white rounded-xl shadow-card overflow-hidden border border-neutral-100 relative">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-neutral-200">
                <thead class="bg-gradient-to-r from-neutral-50 to-neutral-100">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-neutral-600 uppercase tracking-wider">Date</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-blue-700 uppercase tracking-wider">Issue Total</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-emerald-700 uppercase tracking-wider bg-emerald-50/50">Issue Read</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-red-700 uppercase tracking-wider bg-red-50/50">Issue No Read</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-indigo-700 uppercase tracking-wider">Receipt Total</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-emerald-700 uppercase tracking-wider bg-emerald-50/50">Receipt Read</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-red-700 uppercase tracking-wider bg-red-50/50">Receipt No Read</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-neutral-100">
                    @if (Model.Reports != null && Model.Reports.Any())
                    {
                        foreach (var report in Model.Reports)
                        {
                            <tr class="hover:bg-brand-50/30 transition-colors group">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-neutral-900">
                                    @report.ReportDate.ToString("MMM dd, yyyy")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-bold text-blue-700">
                                    @report.IssueTotal.ToString("N0")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-semibold text-emerald-600 bg-emerald-50/20 group-hover:bg-emerald-50/40">
                                    @report.IssueRead.ToString("N0")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-semibold text-red-600 bg-red-50/20 group-hover:bg-red-50/40">
                                    @report.IssueNoRead.ToString("N0")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-bold text-indigo-700">
                                    @report.ReceiptTotal.ToString("N0")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-semibold text-emerald-600 bg-emerald-50/20 group-hover:bg-emerald-50/40">
                                    @report.ReceiptRead.ToString("N0")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-semibold text-red-600 bg-red-50/20 group-hover:bg-red-50/40">
                                    @report.ReceiptNoRead.ToString("N0")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="px-6 py-12 text-center text-neutral-500 flex-col items-center">
                                <svg class="w-12 h-12 text-neutral-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                </svg>
                                <span class="block text-base font-medium">No records found</span>
                                <span class="block text-sm mt-1">Try adjusting the date filters to see results.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
