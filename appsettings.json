{
  "Sync": {
    "SyncIntervalSeconds": 10,
    "BatchSize": 250,
    "MatchWindowMinutes": 60
  },
  "Cleanup": {
    "Enabled": true,
    "RetentionDays": 30,
    "IntervalHours": 12,
    "InitialDelayMinutes": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
